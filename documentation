import { GoogleGenerativeAI } from '@google/generative-ai';
import { prisma } from '../config/database';
import { logger } from '../utils/logger';

export class VectorService {
  private genAI: GoogleGenerativeAI;
  private embeddingModel: any;
  
  constructor() {
    this.genAI = new GoogleGenerativeAI(process.env.GEMINI_API_KEY!);
    this.embeddingModel = this.genAI.getGenerativeModel({ 
      model: "text-embedding-004"
    });
  }

  /**
   * Génère un embedding pour un texte
   */
  async generateEmbedding(text: string): Promise<number[]> {
    try {
      const result = await this.embeddingModel.embedContent({
        content: { parts: [{ text }] }
      });
      return result.embedding.values;
    } catch (error) {
      logger.error('Error generating embedding:', error);
      throw error;
    }
  }

  /**
   * Recherche les documents similaires
   */
  async searchSimilar(query: string, options: {
    limit?: number;
    threshold?: number;
    language?: 'fr' | 'en';
    category?: string;
  } = {}) {
    const { limit = 10, threshold = 0.7, language = 'fr' } = options;
    
    try {
      // 1. Générer l'embedding de la requête
      const queryEmbedding = await this.generateEmbedding(query);
      
      // 2. Recherche vectorielle avec pgvector
      const results = await prisma.$queryRaw`
        SELECT 
          e.id,
          e."documentId",
          e."sectionId",
          e.text,
          e."textEn",
          d.title as document_title,
          d.type as document_type,
          d.reference as document_reference,
          1 - (e.embedding <=> ${queryEmbedding}::vector) as similarity
        FROM "Embedding" e
        LEFT JOIN "Document" d ON e."documentId" = d.id
        WHERE 1 - (e.embedding <=> ${queryEmbedding}::vector) > ${threshold}
        ORDER BY similarity DESC
        LIMIT ${limit}
      `;

      // 3. Formater les résultats
      return results.map((r: any) => ({
        id: r.id,
        text: language === 'en' ? (r.textEn || r.text) : r.text,
        similarity: r.similarity,
        document: {
          id: r.documentId,
          title: r.document_title,
          type: r.document_type,
          reference: r.document_reference
        }
      }));

    } catch (error) {
      logger.error('Error searching similar documents:', error);
      return [];
    }
  }

  /**
   * Indexe un document complet
   */
  async indexDocument(documentId: string) {
    try {
      const document = await prisma.document.findUnique({
        where: { id: documentId },
        include: { sections: true }
      });

      if (!document) {
        throw new Error('Document not found');
      }

      // Chunker le document
      const chunks = this.chunkDocument(document);
      
      // Générer et sauvegarder les embeddings
      for (const chunk of chunks) {
        const embedding = await this.generateEmbedding(chunk.text);
        
        await prisma.embedding.create({
          data: {
            documentId,
            sectionId: chunk.sectionId,
            text: chunk.text,
            textEn: chunk.textEn,
            embedding: embedding,
            tokens: chunk.tokens,
            model: 'text-embedding-004'
          }
        });
      }

      logger.info(`Indexed document ${documentId} with ${chunks.length} chunks`);
      return chunks.length;

    } catch (error) {
      logger.error('Error indexing document:', error);
      throw error;
    }
  }

  /**
   * Découpe un document en chunks
   */
  private chunkDocument(document: any, chunkSize = 500): any[] {
    const chunks = [];
    
    // Chunker le contenu principal
    const mainChunks = this.chunkText(document.content, chunkSize);
    chunks.push(...mainChunks.map((text: string) => ({
      text,
      textEn: document.contentEn ? this.chunkText(document.contentEn, chunkSize)[0] : null,
      sectionId: null,
      tokens: this.countTokens(text)
    })));

    // Chunker les sections
    for (const section of document.sections) {
      const sectionChunks = this.chunkText(section.content, chunkSize);
      chunks.push(...sectionChunks.map((text: string) => ({
        text,
        textEn: section.contentEn,
        sectionId: section.id,
        tokens: this.countTokens(text)
      })));
    }

    return chunks;
  }

  /**
   * Découpe un texte en chunks avec overlap
   */
  private chunkText(text: string, chunkSize: number, overlap: number = 50): string[] {
    const sentences = text.match(/[^.!?]+[.!?]+/g) || [];
    const chunks = [];
    let currentChunk = '';
    let currentTokens = 0;

    for (const sentence of sentences) {
      const sentenceTokens = this.countTokens(sentence);
      
      if (currentTokens + sentenceTokens > chunkSize && currentChunk) {
        chunks.push(currentChunk.trim());
        // Overlap: garder la dernière phrase
        currentChunk = sentences[sentences.indexOf(sentence) - 1] || '';
        currentTokens = this.countTokens(currentChunk);
      }
      
      currentChunk += ' ' + sentence;
      currentTokens += sentenceTokens;
    }

    if (currentChunk.trim()) {
      chunks.push(currentChunk.trim());
    }

    return chunks;
  }

  /**
   * Compte approximatif des tokens
   */
  private countTokens(text: string): number {
    // Approximation: 1 token ≈ 4 caractères
    return Math.ceil(text.length / 4);
  }

  /**
   * Mise à jour des embeddings d'un document
   */
  async updateDocumentEmbeddings(documentId: string) {
    try {
      // Supprimer les anciens embeddings
      await prisma.embedding.deleteMany({
        where: { documentId }
      });

      // Re-indexer
      return await this.indexDocument(documentId);
    } catch (error) {
      logger.error('Error updating document embeddings:', error);
      throw error;
    }
  }
}
