/**

Traite et filtre les articles
*/
private async processArticles(articles: any[], sourceName: string) {
const processed = [];

for (const article of articles) {
  try {
    // Vérifier si l'article existe déjà
    const exists = await prisma.newsArticle.findUnique({
      where: { url: article.url }
    });
    
    if (exists) continue;

    // Analyser la pertinence avec Gemini
    const analysis = await this.analyzeRelevance(article);
    
    if (analysis.isRelevant) {
      const saved = await prisma.newsArticle.create({
        data: {
          title: article.title,
          summary: article.summary || '',
          url: article.url,
          imageUrl: article.image,
          source: sourceName,
          category: analysis.category as any,
          isRelevant: analysis.isRelevant,
          aiSummary: analysis.summary,
          tags: analysis.tags,
          publishedAt: new Date(article.date)
        }
      });
      
      processed.push(saved);
    }
  } catch (error) {
    logger.error('Error processing article:', error);
  }
}

return processed;
}
/**

Analyse la pertinence d'un article
*/
private async analyzeRelevance(article: any) {
const cacheKey = relevance:${this.hashUrl(article.url)};
const cached = await this.cacheService.get(cacheKey);

if (cached) {
  return JSON.parse(cached);
}

const prompt = `
Analyse cet article d'actualité camerounaise et détermine s'il est pertinent pour notre plateforme.
Titre: ${article.title}
Résumé: ${article.summary}
Réponds en JSON:
{
"isRelevant": boolean, // true si juridique, administratif, culturel ou économique important
"category": "JURIDIQUE|POLITIQUE|ECONOMIE|SOCIETE|CULTURE|SPORT|INTERNATIONAL",
"summary": "Résumé en 2 phrases max",
"tags": ["tag1", "tag2"],
"relevanceScore": 0.0-1.0
}`;
try {
  const result = await this.geminiService.model.generateContent(prompt);
  const analysis = JSON.parse(result.response.text());
  
  await this.cacheService.set(cacheKey, JSON.stringify(analysis), 86400); // Cache 24h
  return analysis;
} catch (error) {
  logger.error('Error analyzing relevance:', error);
  return {
    isRelevant: false,
    category: 'AUTRE',
    summary: article.summary,
    tags: [],
    relevanceScore: 0
  };
}
}
/**

Normalise une URL
*/
private normalizeUrl(url: string | undefined, baseUrl: string): string {
if (!url) return '';
if (url.startsWith('http')) return url;
if (url.startsWith('//')) return 'https:' + url;
if (url.startsWith('/')) return new URL(url, baseUrl).href;
return new URL(url, baseUrl).href;
}

/**

Hash une URL pour le cache
*/
private hashUrl(url: string): string {
const crypto = require('crypto');
return crypto.createHash('md5').update(url).digest('hex');
}

