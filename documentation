    } catch (error) {
      logger.error('Error importing bulk PDFs:', error);
      throw error;
    }
  }

  /**
   * Devine les métadonnées depuis le nom du fichier
   */
  private guessMetadata(filename: string) {
    const name = filename.replace('.pdf', '');
    
    // Déterminer le type
    let type = 'LOI';
    let category = 'DROIT_CIVIL';
    
    if (name.includes('code_penal')) {
      type = 'CODE';
      category = 'DROIT_PENAL';
    } else if (name.includes('constitution')) {
      type = 'CONSTITUTION';
      category = 'DROIT_CONSTITUTIONNEL';
    } else if (name.includes('code_travail')) {
      type = 'CODE';
      category = 'DROIT_TRAVAIL';
    } else if (name.includes('decret')) {
      type = 'DECRET';
    } else if (name.includes('arrete')) {
      type = 'ARRETE';
    }

    return {
      title: name.replace(/_/g, ' ').replace(/-/g, ' '),
      type,
      category,
      source: `Import automatique - ${new Date().toISOString()}`
    };
  }
}
