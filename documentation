export class DocumentsController {
  /**
   * Recherche de documents
   */
  async search(req: Request, res: Response) {
    try {
      const { 
        q, 
        type, 
        category, 
        status = 'ACTIVE',
        page = 1, 
        limit = 20 
      } = req.query;

      const where: any = { status };
      
      if (q) {
        where.OR = [
          { title: { contains: q as string, mode: 'insensitive' } },
          { content: { contains: q as string, mode: 'insensitive' } },
          { reference: { contains: q as string, mode: 'insensitive' } }
        ];
      }
      
      if (type) where.type = type;
      if (category) where.category = category;

      const [documents, total] = await Promise.all([
        prisma.document.findMany({
          where,
          skip: (Number(page) - 1) * Number(limit),
          take: Number(limit),
          select: {
            id: true,
            slug: true,
            title: true,
            type: true,
            category: true,
            summary: true,
            reference: true,
            dateEnacted: true,
            tags: true
          },
          orderBy: { createdAt: 'desc' }
        }),
        prisma.document.count({ where })
      ]);

      res.json({
        success: true,
        data: {
          documents,
          pagination: {
            page: Number(page),
            limit: Number(limit),
            total,
            pages: Math.ceil(total / Number(limit))
          }
        }
      });

    } catch (error) {
      logger.error('Document search error:', error);
      res.status(500).json({
        success: false,
        error: 'Erreur lors de la recherche'
      });
    }
  }

  /**
   * Récupère un document par slug
   */
  async getBySlug(req: Request, res: Response) {
    try {
      const { slug } = req.params;
      const { includeSections = 'true' } = req.query;

      const document = await prisma.document.findUnique({
        where: { slug },
        include: {
          sections: includeSections === 'true' ? {
            orderBy: { position: 'asc' }
          } : false
        }
      });

      if (!document) {
        return res.status(404).json({
          success: false,
          error: 'Document non trouvé'
        });
      }

      // Analytics
      await prisma.analytics.create({
        data: {
          event: 'DOCUMENT_VIEW',
          sessionId: req.sessionID || req.ip,
          data: { documentId: document.id, slug },
          language: 'FR',
          userAgent: req.get('user-agent')
        }
      });

      res.json({
        success: true,
        data: document
      });

