import * as fs from 'fs/promises';
import * as path from 'path';
import pdfParse from 'pdf-parse';
import { prisma } from '../config/database';
import { VectorService } from './vector.service';
import { logger } from '../utils/logger';

export class ExtractionService {
  private vectorService: VectorService;

  constructor() {
    this.vectorService = new VectorService();
  }

  /**
   * Extrait le contenu d'un PDF
   */
  async extractPDF(filePath: string): Promise<{
    text: string;
    pages: number;
    info: any;
  }> {
    try {
      const dataBuffer = await fs.readFile(filePath);
      const data = await pdfParse(dataBuffer);
      
      return {
        text: this.cleanText(data.text),
        pages: data.numpages,
        info: data.info
      };
    } catch (error) {
      logger.error('Error extracting PDF:', error);
      throw error;
    }
  }

  /**
   * Nettoie le texte extrait
   */
  private cleanText(text: string): string {
    return text
      .replace(/\r\n/g, '\n')           // Normaliser les sauts de ligne
      .replace(/\n{3,}/g, '\n\n')       // Limiter les sauts de ligne multiples
      .replace(/\s+/g, ' ')             // Normaliser les espaces
      .replace(/[^\S\n]+/g, ' ')        // Garder seulement espaces simples
      .trim();
  }

  /**
   * Parse un document juridique structuré
   */
  async parseJuridicalDocument(text: string, metadata: any) {
    const structure = {
      title: '',
      type: '',
      reference: '',
      dateEnacted: null as Date | null,
      preamble: '',
      sections: [] as any[],
      articles: [] as any[]
    };

    // Extraire le titre et la référence
    const titleMatch = text.match(/^(LOI|DÉCRET|ARRÊTÉ|CODE)\s+N°\s*([^\n]+)/i);
    if (titleMatch) {
      structure.type = titleMatch[1].toUpperCase();
      structure.reference = titleMatch[0];
    }

    // Parser les sections et articles
    const articleRegex = /Article\s+(\d+)\s*[:\-.]?\s*([^Article]*)/gi;
    let match;
    let position = 0;

    while ((match = articleRegex.exec(text)) !== null) {
      position++;
      structure.articles.push({
        number: parseInt(match[1]),
        content: this.cleanText(match[2]),
        position
      });
    }

    // Parser les chapitres/titres
    const sectionRegex = /(TITRE|CHAPITRE|SECTION)\s+([IVXLCDM\d]+)\s*[:\-.]?\s*([^\n]+)/gi;
    while ((match = sectionRegex.exec(text)) !== null) {
      structure.sections.push({
        type: match[1],
        number: match[2],
        title: this.cleanText(match[3]),
        level: match[1] === 'TITRE' ? 1 : match[1] === 'CHAPITRE' ? 2 : 3
      });
    }

    return structure;
  }

  /**
   * Importe un document dans la base de données
   */
  async importDocument(filePath: string, metadata: {
    title: string;
    type: string;
    category: string;
    source?: string;
  }) {
    try {
      logger.info(`Importing document: ${filePath}`);

      // 1. Extraire le contenu
      const { text, pages, info } = await this.extractPDF(filePath);

      // 2. Parser la structure
      const structure = await this.parseJuridicalDocument(text, metadata);

      // 3. Créer le slug
      const slug = this.generateSlug(metadata.title);

      // 4. Sauvegarder en base
      const document = await prisma.document.create({
        data: {
          slug,
          title: metadata.title,
          type: metadata.type as any,
          category: metadata.category as any,
          source: metadata.source || path.basename(filePath),
          sourceFile: path.basename(filePath),
          content: text,
          summary: this.generateSummary(text),
          reference: structure.reference,
          dateEnacted: structure.dateEnacted,
          tags: this.extractTags(text),
          sections: {
            create: structure.sections.map((section, index) => ({
              title: section.title,
              content: this.extractSectionContent(text, section, structure.sections[index + 1]),
              position: index,
              level: section.level,
              reference: `${section.type} ${section.number}`
            }))
          }
        }
      });

      // 5. Générer les embeddings
      await this.vectorService.indexDocument(document.id);

      logger.info(`Document imported successfully: ${document.id}`);
      return document;

    } catch (error) {
      logger.error('Error importing document:', error);
      throw error;
    }
  }

  /**
   * Extrait le contenu d'une section
   */
  private extractSectionContent(text: string, currentSection: any, nextSection: any): string {
    const startPattern = `${currentSection.type}\\s+${currentSection.number}`;
    const endPattern = nextSection ? `${nextSection.type}\\s+${nextSection.number}` : null;

    const startMatch = text.search(new RegExp(startPattern, 'i'));
    if (startMatch === -1) return '';

    const startPos = startMatch;
    const endPos = endPattern ? text.search(new RegExp(endPattern, 'i')) : text.length;

    return this.cleanText(text.substring(startPos, endPos > startPos ? endPos : text.length));
  }

  /**
   * Génère un résumé automatique
   */
  private generateSummary(text: string, maxLength: number = 500): string {
    // Prendre le début du texte après le titre
    const cleanedText = text.replace(/^(LOI|DÉCRET|ARRÊTÉ|CODE)[^\.]+\./i, '');
    const firstParagraphs = cleanedText.substring(0, maxLength * 2);
    
    // Trouver la fin de la dernière phrase complète
    const lastPeriod = firstParagraphs.lastIndexOf('.');
    if (lastPeriod > 0 && lastPeriod < maxLength) {
      return firstParagraphs.substring(0, lastPeriod + 1).trim();
    }
    
    return firstParagraphs.substring(0, maxLength).trim() + '...';
  }

  /**
   * Extrait les tags pertinents
   */
  private extractTags(text: string): string[] {
    const tags = new Set<string>();
    
    // Mots-clés juridiques courants
    const keywords = [
      'obligation', 'droit', 'devoir', 'sanction', 'amende', 'emprisonnement',
      'procédure', 'tribunal', 'juge', 'avocat', 'contrat', 'propriété',
      'succession', 'mariage', 'divorce', 'travail', 'salaire', 'licenciement',
      'impôt', 'taxe', 'douane', 'entreprise', 'société', 'commerce'
    ];

    for (const keyword of keywords) {
      if (text.toLowerCase().includes(keyword)) {
        tags.add(keyword);
      }
    }

    return Array.from(tags);
  }

  /**
   * Génère un slug unique
   */
  private generateSlug(title: string): string {
    const base = title
      .toLowerCase()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '') // Retirer les accents
      .replace(/[^a-z0-9]/g, '-')      // Remplacer caractères spéciaux
      .replace(/-+/g, '-')              // Remplacer multiples tirets
      .replace(/^-|-$/g, '');           // Retirer tirets début/fin

    return `${base}-${Date.now().toString(36)}`;
  }

