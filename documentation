  }

  /**
   * Endpoint principal du chat
   */
  async chat(req: Request, res: Response) {
    try {
      // Validation
      const data = ChatRequestSchema.parse(req.body);
      
      // Récupérer ou créer la conversation
      let conversationId = data.conversationId;
      
      if (!conversationId) {
        const sessionId = req.sessionID || req.ip;
        const conversation = await prisma.conversation.create({
          data: {
            sessionId,
            language: data.language === 'fr' ? 'FR' : 'EN'
          }
        });
        conversationId = conversation.id;
      }

      // Générer la réponse
      const response = await this.geminiService.generateResponse(
        data.message,
        conversationId,
        data.language
      );

      // Analytics
      await prisma.analytics.create({
        data: {
          event: 'CHAT_MESSAGE',
          sessionId: req.sessionID || req.ip,
          data: {
            conversationId,
            messageLength: data.message.length,
            language: data.language,
            confidence: response.confidence
          },
          language: data.language === 'fr' ? 'FR' : 'EN',
          userAgent: req.get('user-agent')
        }
      });

      res.json({
        success: true,
        data: {
          conversationId,
          response: response.answer,
          citations: response.citations,
          relatedProcedures: response.relatedProcedures,
          confidence: response.confidence,
          processingTime: response.processingTime,
          suggestedQuestions: await this.getSuggestedQuestions(data.message, data.language)
        }
      });

    } catch (error) {
      logger.error('Chat error:', error);
      res.status(500).json({
        success: false,
        error: 'Une erreur est survenue lors du traitement de votre message'
      });
    }
  }

