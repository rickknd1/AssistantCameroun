  /**
   * Construit le contexte RAG avec les documents pertinents
   */
  private async buildRAGContext(question: string, language: 'fr' | 'en') {
    try {
      // 1. Recherche vectorielle
      const relevantChunks = await this.vectorService.searchSimilar(question, {
        limit: 10,
        threshold: 0.7,
        language
      });

      // 2. Recherche full-text pour compléter
      const textResults = await prisma.document.findMany({
        where: {
          OR: [
            { content: { contains: question, mode: 'insensitive' } },
            { title: { contains: question, mode: 'insensitive' } }
          ],
          status: 'ACTIVE'
        },
        select: {
          id: true,
          title: true,
          type: true,
          reference: true,
          content: true,
          sections: {
            select: {
              title: true,
              content: true,
              reference: true
            }
          }
        },
        take: 5
      });

      // 3. Combiner et formater le contexte
      const context = {
        vectorResults: relevantChunks.map(chunk => ({
          text: chunk.text,
          source: chunk.document?.title || 'Document',
          relevance: chunk.similarity
        })),
        textResults: textResults.map(doc => ({
          title: doc.title,
          type: doc.type,
          reference: doc.reference,
          excerpt: this.extractRelevantExcerpt(doc.content, question)
        }))
      };

      return context;
    } catch (error) {
      logger.error('Error building RAG context:', error);
      return { vectorResults: [], textResults: [] };
    }
  }

  /**
   * Construit le prompt avec le contexte
   */
  private buildPrompt(question: string, context: any, language: 'fr' | 'en'): string {
    const contextText = [
      "DOCUMENTS PERTINENTS TROUVÉS:",
      ...context.vectorResults.map((r: any) => 
        `- [${r.source}] (Pertinence: ${r.relevance.toFixed(2)}): "${r.text}"`
      ),
      ...context.textResults.map((r: any) =>
        `- [${r.title}] (${r.type}): "${r.excerpt}"`
      )
    ].join('\n');

    return `
QUESTION DE L'UTILISATEUR:
${question}

LANGUE DEMANDÉE: ${language === 'fr' ? 'Français' : 'English'}

CONTEXTE DE LA BASE DE DONNÉES:
${contextText}

INSTRUCTIONS IMPORTANTES:
1. Réponds UNIQUEMENT en JSON valide selon le format spécifié
2. Base ta réponse sur les documents fournis en contexte
3. Cite précisément les sources avec les articles exacts
4. Si l'information n'est pas dans le contexte, indique-le clairement
5. Adapte le niveau de langage pour être compréhensible par tous
6. Pour les questions culturelles/historiques sur le Cameroun, tu peux utiliser tes connaissances générales
7. Inclus les émojis appropriés dans la réponse pour la rendre plus conviviale

Génère maintenant la réponse complète en JSON.`;
  }

  /**
   * Extrait un passage pertinent du document
   */
  private extractRelevantExcerpt(content: string, question: string, maxLength: number = 300): string {
    const words = question.toLowerCase().split(' ').filter(w => w.length > 3);
    let bestExcerpt = '';
    let bestScore = 0;

    // Diviser le contenu en phrases
    const sentences = content.split(/[.!?]+/);
    
    for (let i = 0; i < sentences.length; i++) {
      const sentence = sentences[i].toLowerCase();
      let score = 0;
      
      // Calculer le score de pertinence
      for (const word of words) {
        if (sentence.includes(word)) score++;
      }
      
      if (score > bestScore) {
        bestScore = score;
        // Prendre cette phrase + contexte
        const start = Math.max(0, i - 1);
        const end = Math.min(sentences.length, i + 2);
        bestExcerpt = sentences.slice(start, end).join('. ');
      }
    }

    // Tronquer si nécessaire
    if (bestExcerpt.length > maxLength) {
      bestExcerpt = bestExcerpt.substring(0, maxLength) + '...';
    }

    return bestExcerpt || content.substring(0, maxLength) + '...';
  }

  /**
   * Enrichit les citations avec les métadonnées
   */
  private async enrichCitations(citations: any[]) {
    const enriched = [];
    
    for (const citation of citations) {
      try {
        // Rechercher le document source
        const document = await prisma.document.findFirst({
          where: {
            OR: [
              { title: { contains: citation.source, mode: 'insensitive' } },
              { reference: { contains: citation.source, mode: 'insensitive' } }
            ]
          },
          select: {
            id: true,
            title: true,
            reference: true,
            slug: true,
            type: true,
            source: true
          }
        });

        enriched.push({
          ...citation,
          documentId: document?.id,
          documentSlug: document?.slug,
          documentUrl: document ? `/bibliotheque/${document.slug}` : null,
          officialSource: document?.source
        });
      } catch (error) {
        logger.error('Error enriching citation:', error);
        enriched.push(citation);
      }
    }
    
    return enriched;
  }

  /**
   * Récupère l'historique de conversation
   */
  private async getConversationHistory(conversationId: string): Promise<Content[]> {
    try {
      const messages = await prisma.message.findMany({
        where: { conversationId },
        orderBy: { createdAt: 'asc' },
        take: 10 // Derniers 10 messages pour le contexte
      });

      return messages.map(msg => ({
        role: msg.role === 'USER' ? 'user' : 'model',
        parts: [{ text: msg.content }]
      }));
    } catch (error) {
      logger.error('Error fetching conversation history:', error);
      return [];
    }
  }

  /**
   * Sauvegarde le message en base de données
   */
  private async saveMessage(conversationId: string, question: string, response: any) {
    try {
      // Sauvegarder la question
      await prisma.message.create({
        data: {
          conversationId,
          role: 'USER',
          content: question,
          language: response.language === 'fr' ? 'FR' : 'EN'
        }
      });

      // Sauvegarder la réponse avec citations
      const assistantMessage = await prisma.message.create({
        data: {
          conversationId,
          role: 'ASSISTANT',
          content: response.answer,
          confidence: response.confidence,
          language: response.language === 'fr' ? 'FR' : 'EN',
          tokensUsed: response.tokensUsed,
          citations: {
            create: response.citations.map((c: any) => ({
              documentId: c.documentId,
              excerpt: c.text,
              reference: c.article || c.source,
              relevance: c.relevance
            }))
          }
        }
      });

      return assistantMessage;
    } catch (error) {
      logger.error('Error saving message:', error);
    }
  }

  /**
   * Hash la question pour le cache
   */
  private hashQuestion(question: string): string {
    const crypto = require('crypto');
    return crypto.createHash('md5').update(question.toLowerCase().trim()).digest('hex');
  }

  /**
   * Génère des questions suggérées basées sur le contexte
   */
  async generateSuggestedQuestions(topic: string, language: 'fr' | 'en' = 'fr') {
    const prompt = `
Génère 5 questions pertinentes que les citoyens camerounais pourraient poser sur le sujet: "${topic}"

Retourne UNIQUEMENT un array JSON de strings:
["Question 1", "Question 2", "Question 3", "Question 4", "Question 5"]

Langue: ${language === 'fr' ? 'Français' : 'English'}
Les questions doivent être pratiques et utiles pour la vie quotidienne.`;

