🗄️ 3. SCHÉMA BASE DE DONNÉES PRISMA
prisma// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== DOCUMENTS ====================
model Document {
  id            String   @id @default(cuid())
  slug          String   @unique
  title         String
  titleEn       String?  // Titre anglais
  
  // Métadonnées
  type          DocumentType
  category      Category
  subcategory   String?
  source        String   // URL ou référence officielle
  sourceFile    String?  // Nom du PDF original
  
  // Contenu
  content       String   @db.Text // Texte complet
  contentEn     String?  @db.Text // Traduction anglaise
  summary       String?  @db.Text // Résumé auto-généré
  summaryEn     String?  @db.Text
  
  // Métadonnées juridiques
  reference     String?  // Ex: "Loi n°2024/001"
  dateEnacted   DateTime? // Date de promulgation
  dateEffective DateTime? // Date d'entrée en vigueur
  status        DocumentStatus @default(ACTIVE)
  
  // Recherche
  searchVector  Unsupported("tsvector")?
  tags          String[]
  
  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastCrawled   DateTime?
  
  // Relations
  sections      Section[]
  embeddings    Embedding[]
  citations     Citation[]
  quizQuestions QuizQuestion[]
  
  @@index([type, category])
  @@index([status])
  @@index([slug])
}

model Section {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  
  title      String
  content    String   @db.Text
  contentEn  String?  @db.Text
  
  // Hiérarchie
  parentId   String?
  parent     Section? @relation("SectionHierarchy", fields: [parentId], references: [id])
  children   Section[] @relation("SectionHierarchy")
  
  // Position dans le document
  position   Int
  level      Int      // 1 = Titre, 2 = Chapitre, 3 = Article
  reference  String?  // Ex: "Article 15"
  
  embeddings Embedding[]
  
  @@index([documentId, position])
}

// ==================== EMBEDDINGS & RECHERCHE ====================
model Embedding {
  id         String   @id @default(cuid())
  
  // Source
  documentId String?
  document   Document? @relation(fields: [documentId], references: [id], onDelete: Cascade)
  sectionId  String?
  section    Section?  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  
  // Contenu
  text       String   @db.Text // Chunk de texte
  textEn     String?  @db.Text
  
  // Vector (1536 dimensions pour text-embedding-004)
  embedding  Unsupported("vector(768)")?
  
  // Métadonnées
  model      String   @default("text-embedding-004")
  tokens     Int      // Nombre de tokens
  
  createdAt  DateTime @default(now())
  
  @@index([documentId])
  @@index([sectionId])
}

// ==================== CHAT & CONVERSATIONS ====================
model Conversation {
  id         String    @id @default(cuid())
  sessionId  String    // ID de session (sans auth)
  
  language   Language  @default(FR)
  topic      String?   // Sujet détecté
  
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  
  messages   Message[]
  
  @@index([sessionId])
  @@index([createdAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  role           MessageRole
  content        String       @db.Text
  
  // Pour les réponses de l'assistant
  confidence     Float?       // Score de confiance
  processingTime Int?         // Temps de traitement en ms
  tokensUsed     Int?
  
  // Métadonnées
  language       Language
  error          String?      // Si erreur
  
  createdAt      DateTime     @default(now())
  
  citations      Citation[]
  feedback       Feedback?
  
  @@index([conversationId, createdAt])
}

model Citation {
  id         String   @id @default(cuid())
  messageId  String
  message    Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  
  documentId String
  document   Document @relation(fields: [documentId], references: [id])
  
  excerpt    String   @db.Text // Extrait cité
  reference  String   // Ex: "Article 15, alinéa 2"
  relevance  Float    // Score de pertinence
  
  @@index([messageId])
}

// ==================== QUIZ & EDUCATION ====================
model QuizQuestion {
  id         String   @id @default(cuid())
  
  // Contenu
  question   String   @db.Text
  questionEn String?  @db.Text
  options    Json     // {a: "...", b: "...", c: "...", d: "..."}
  answer     String   // "a", "b", "c", ou "d"
  explanation String  @db.Text
  
  // Catégorie
  category   Category
  difficulty Difficulty
  
  // Source
  documentId String?
  document   Document? @relation(fields: [documentId], references: [id])
  
  // Stats
  timesAsked Int      @default(0)
  correctRate Float   @default(0)
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  attempts   QuizAttempt[]
  
  @@index([category, difficulty])
}

model QuizAttempt {
  id         String       @id @default(cuid())
  sessionId  String
  questionId String
  question   QuizQuestion @relation(fields: [questionId], references: [id])
  
  answer     String       // Réponse donnée
  isCorrect  Boolean
  timeSpent  Int          // Secondes
  
  createdAt  DateTime     @default(now())
  
  @@index([sessionId])
}

// ==================== ACTUALITÉS ====================
model NewsArticle {
  id          String   @id @default(cuid())
  
  title       String
  summary     String   @db.Text
  content     String?  @db.Text
  url         String   @unique
  imageUrl    String?
  
  source      String   // "Cameroon Tribune", etc.
  category    NewsCategory
  
  // IA
  isRelevant  Boolean  @default(true) // Pertinent juridiquement
  aiSummary   String?  @db.Text       // Résumé Gemini
  tags        String[]
  
  publishedAt DateTime
  createdAt   DateTime @default(now())
  
  @@index([publishedAt])
  @@index([category])
}

// ==================== PROCEDURES ====================
model Procedure {
  id          String   @id @default(cuid())
  slug        String   @unique
  
  name        String
  nameEn      String?
  description String   @db.Text
  
  category    ProcedureCategory
  
  // Détails
  steps       Json     // [{order: 1, title: "...", description: "..."}]
  documents   String[] // Documents requis
  costs       Json     // {base: 10000, optional: {...}}
  duration    String   // "48h", "2-3 semaines"
  locations   Json     // [{name: "...", address: "...", hours: "..."}]
  
  // Liens
  onlineUrl   String?  // Si disponible en ligne
  formUrl     String?  // Formulaire PDF
  
  popularity  Int      @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([category])
  @@index([slug])
}

// ==================== ANALYTICS ====================
model Analytics {
  id        String   @id @default(cuid())
  
  event     EventType
  sessionId String
  
  // Données
  data      Json     // Données spécifiques à l'événement
  
  // Contexte
  language  Language
  userAgent String?
  ip        String?  // Hashé pour privacy
  
  createdAt DateTime @default(now())
  
  @@index([event, createdAt])
  @@index([sessionId])
}

model Feedback {
  id        String   @id @default(cuid())
  messageId String   @unique
  message   Message  @relation(fields: [messageId], references: [id])
  
  rating    Int      // 1-5
  comment   String?  @db.Text
  
  createdAt DateTime @default(now())
}

// ==================== ENUMS ====================
enum DocumentType {
