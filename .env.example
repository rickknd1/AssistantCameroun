# ============================================
# ASSISTANT NATIONAL DU CAMEROUN
# Variables d'environnement
# ============================================

# ============================================
# SUPABASE (Database & Authentication)
# ============================================
# URL de votre projet Supabase
# Exemple : https://votreprojet.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Clé anonyme publique Supabase (safe pour le client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Clé secrète Supabase (NE PAS exposer côté client - backend uniquement)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ============================================
# GOOGLE GEMINI AI
# ============================================
# Clé API Gemini pour le backend
# Obtenir gratuitement sur : https://ai.google.dev
GEMINI_API_KEY=your_gemini_api_key_here

# Clé API Gemini pour le frontend (Vite)
# Note : Si vous utilisez Vite dans un sous-projet
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# GOOGLE CUSTOM SEARCH (Recherche Web)
# ============================================
# Clé API Google Custom Search (optionnel - pour la recherche web)
# Obtenir sur : https://console.cloud.google.com/apis/credentials
# 100 requêtes/jour gratuites
GOOGLE_SEARCH_API_KEY=

# ID du moteur de recherche personnalisé
# Créer sur : https://programmablesearchengine.google.com/
GOOGLE_SEARCH_ENGINE_ID=

# ============================================
# GOOGLE TRANSLATE API (Traduction Contenus Dynamiques)
# ============================================
# Clé API Google Cloud Translation
# Obtenir sur : https://console.cloud.google.com/apis/credentials
# 500,000 caractères/mois GRATUITS
# Activer l'API : https://console.cloud.google.com/apis/library/translate.googleapis.com
GOOGLE_TRANSLATE_API_KEY=

# ============================================
# DATABASE (Backend - Prisma)
# ============================================
# URL de connexion PostgreSQL pour Prisma
# Format : postgresql://user:password@host:port/database?schema=public
DATABASE_URL=postgresql://user:password@host:5432/assistant_cameroun?schema=public

# ============================================
# REDIS (Cache & Queue)
# ============================================
# URL de connexion Redis
# Upstash Redis : redis://default:password@host:port
REDIS_URL=redis://default:password@localhost:6379

# ============================================
# CLOUDINARY (Storage PDFs)
# ============================================
# Cloudinary Cloud Name
CLOUDINARY_CLOUD_NAME=your_cloud_name

# Cloudinary API Key
CLOUDINARY_API_KEY=your_api_key

# Cloudinary API Secret
CLOUDINARY_API_SECRET=your_api_secret

# ============================================
# SENTRY (Monitoring & Error Tracking)
# ============================================
# Sentry DSN pour le monitoring des erreurs
SENTRY_DSN=your_sentry_dsn_here

# Environnement (development, staging, production)
SENTRY_ENVIRONMENT=development

# ============================================
# VERCEL (Déploiement)
# ============================================
# Configurées automatiquement par Vercel
# Pas besoin de les définir localement
# VERCEL_URL=
# VERCEL_ENV=

# ============================================
# APPLICATION CONFIG
# ============================================
# URL de base de l'application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# URL de l'API backend (si séparée)
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Environnement
NODE_ENV=development

# ============================================
# RATE LIMITING
# ============================================
# Nombre de requêtes max par IP (par minute)
RATE_LIMIT_MAX_REQUESTS=60

# Fenêtre de temps en ms (60000 = 1 minute)
RATE_LIMIT_WINDOW_MS=60000

# ============================================
# AI CONFIGURATION
# ============================================
# Modèle Gemini à utiliser
GEMINI_MODEL=gemini-2.0-flash-exp

# Température (0.0 - 1.0, plus bas = plus déterministe)
GEMINI_TEMPERATURE=0.3

# Tokens maximum pour les réponses
GEMINI_MAX_OUTPUT_TOKENS=4096

# ============================================
# EMBEDDINGS & RAG
# ============================================
# Modèle d'embeddings
EMBEDDING_MODEL=text-embedding-004

# Dimensions des vecteurs (768 pour text-embedding-004)
EMBEDDING_DIMENSIONS=768

# Seuil de similarité pour la recherche vectorielle (0.0 - 1.0)
VECTOR_SIMILARITY_THRESHOLD=0.7

# Nombre de résultats vectoriels à récupérer
VECTOR_SEARCH_LIMIT=10

# ============================================
# CACHE CONFIGURATION
# ============================================
# Durée du cache pour les réponses IA (en secondes)
CACHE_RESPONSE_TTL=1800

# Durée du cache pour les actualités (en secondes)
CACHE_NEWS_TTL=86400

# ============================================
# SCRAPING & CRAWLING
# ============================================
# User-Agent pour le scraping
SCRAPER_USER_AGENT="Mozilla/5.0 (compatible; AssistantCamerounBot/1.0)"

# Délai entre les requêtes de scraping (ms)
SCRAPER_DELAY_MS=2000

# ============================================
# ADMIN AUTHENTICATION
# ============================================
# Clé secrète pour les JWT admin
ADMIN_JWT_SECRET=your_super_secret_jwt_key_change_this

# Durée de validité des tokens admin (en heures)
ADMIN_TOKEN_EXPIRY_HOURS=24

# ============================================
# LOGS
# ============================================
# Niveau de log (debug, info, warn, error)
LOG_LEVEL=info

# ============================================
# JOBS & CRON
# ============================================
# Activer les jobs automatiques (true/false)
ENABLE_JOBS=true

# Fréquence du crawling des actualités (cron format)
# Ex: "0 */6 * * *" = toutes les 6 heures
NEWS_CRAWL_SCHEDULE="0 */6 * * *"

# Fréquence de mise à jour des embeddings (cron format)
EMBEDDINGS_UPDATE_SCHEDULE="0 2 * * *"

# ============================================
# FEATURES FLAGS
# ============================================
# Activer le mode maintenance
MAINTENANCE_MODE=false

# Activer l'inscription publique (false = admin only)
ENABLE_PUBLIC_SIGNUP=false

# Activer les analytics
ENABLE_ANALYTICS=true

# Activer le mode debug
DEBUG=false